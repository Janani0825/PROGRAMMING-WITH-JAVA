import java.util.Scanner;

public class Calculator {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);


        Operation add = (a, b) -> System.out.println("Result: " + (a + b));
        Operation subtract = (a, b) -> System.out.println("Result: " + (a - b));
        Operation multiply = (a, b) -> System.out.println("Result: " + (a * b));
        Operation divide = (a, b) -> {
            if (b != 0) {
                System.out.println("Result: " + (a / b));
            } else {
                System.out.println("Invalid divisor: Division by zero");
            }
        };


        System.out.print("\nEnter first number: ");
        double num1 = sc.nextDouble();

        System.out.print("Enter second number: ");
        double num2 = sc.nextDouble();

        System.out.println("Choose operation: +  -  *  /");
        String op = sc.next();

        if (op.equals("+")) {
            add.calculate(num1, num2);
        } else if (op.equals("-")) {
            subtract.calculate(num1, num2);
        } else if (op.equals("*")) {
            multiply.calculate(num1, num2);
        } else if (op.equals("/")) {
            divide.calculate(num1, num2);
        } else {
            System.out.println("Invalid operation");
        }

        sc.close();
    }
}
interface Operation {
    void calculate(double a, double b);
}

