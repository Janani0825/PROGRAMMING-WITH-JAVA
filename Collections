import java.util.Stack;
class Student {
    int id;
    String name;
    float cgpa;
    Student(int id, String name, float cgpa) {
        this.id = id;
        this.name = name;
        this.cgpa = cgpa;
    }
}
public class StudentPgm {
    public static void main(String[] args) {
        Stack<Student> s = new Stack<>();
        s.add(new Student(1, "Janani", 98.72f));
        s.add(new Student(2, "Kanya", 97.91f));
        s.add(new Student(3, "Rubika", 99.82f));
        s.add(new Student(4, "Kanya", 96.91f));
        System.out.println("Student Details");
        while (!s.isEmpty()) {
            Student stud = s.pop();
            System.out.println("ID: " + stud.id + ", Name: " + stud.name + ", CGPA: " + stud.cgpa);
        }
    }
}
