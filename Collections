import java.util.*;

public class QueueToStack {

    public static void main(String[] args) {
        Queue<Integer> q1 = new PriorityQueue<>();
        Queue<Integer> q2 = new PriorityQueue<>();
        q1.add(1);
        q1.add(2);
        q1.add(3);
        q2.add(4);
        q2.add(5);
        q2.add(6);
        System.out.println("Elements in Queue 1 : " + q1);
        System.out.println("Elements in Queue 2 : " + q2);
        Stack<Integer> s = new Stack<>();
        for (int num1 : q1) {
            s.add(num1);
        }
        for (int num2 : q2) {
            s.add(num2);
        }
        System.out.println("Stack after adding elements: " + s);
        System.out.println("Displaying elements by popping from stack:");
        while (!s.isEmpty()) {
            System.out.println(s.pop());
        }
    }
}

